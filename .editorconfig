root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,h,hpp}]
indent_style = space
indent_size = 4

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

[*.{md,frc}]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false

[CMakeLists.txt]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4
